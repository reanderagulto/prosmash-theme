{{ "mdp-weare-menu-1.css" | asset_url | stylesheet_tag }}
{{ "prosmash-header.css" | asset_url | stylesheet_tag }}
{{ "prosmash-header.js" |  asset_url |  script_tag }}

{% assign logo = section.settings.logo | img_url: section.settings.logo_size %}

<div id="mdp-weare-{{ section.id }}"
     class="mdp mdp-weare-menu-1">
    <div id="mdp-right-icon" style="display: none;">
        {% render 'mdp-weare-icon' with '007' %}
    </div>
    <div id="mdp-left-icon" style="display: none;">
        {% render 'mdp-weare-icon' with '006' %}
    </div>
    <div id="mdp-back" style="display: none;">
        {{ 'layout.navigation.back' | t }}
    </div>
    <div data-sticky-class="mdp-sticky-menu">
        <div class="top-header">
           <div class="mdp-container mdp-grid" data-columns="1" data-gap="30">
            <div class="mdp-col mdp-row-full">
              <div class="mdp-row-center">
                    {% if section.settings.menu != blank %}
                        <div class="mdp-menu-element" data-mega-menu="12">

                            <div class="mdp-menu-wrapper">
                                <div class="mdp-menu-root">

                                    <div class="mdp-mobile-devices-header">
                                        <a href="/" class="mdp-logo">
                                            {% if section.settings.use_logo_img == false %}
                                                <span>{{ shop.name }}</span>
                                            {% else %}
                                                <img src="{{ logo }}" alt="logo">
                                            {% endif %}
                                        </a>
                                    </div>

                                    {% for link in linklists[section.settings.menu].links %}
                                        {% assign link_classes = '' %}
                                        {% if link.active %}
                                            {% assign link_classes = link_classes | append: ' mdp-active' %}
                                        {% endif %}
                                        {% if link.child_active %}
                                            {% assign link_classes = link_classes | append: ' mdp-active-ancestor' %}
                                        {% endif %}
                                        {% if link.current %}
                                            {% assign link_classes = link_classes | append: ' mdp-current' %}
                                        {% endif %}
                                        {% if link.child_current %}
                                            {% assign link_classes = link_classes | append: ' mdp-current-ancestor' %}
                                        {% endif %}
                                        {% if link.links != blank %}
                                            <div class="mdp-menu-item mdp-has-children{{ link_classes }}">
                                                <a href="{{ link.url }}" class="mdp-menu-link">
                                                    {{ link.title | escape }}
                                                    <span class="mdp-down-icon"><i class="fas fa-angle-down"></i></span>
                                                </a>
                                                <input id="{{ link.url | md5 | slice: 0, 5 | prepend: 'id' }}"
                                                       type="checkbox">
                                                <label for="{{ link.url | md5 | slice: 0, 5 | prepend: 'id' }}"><span
                                                            class="mdp-down-icon"><i
                                                                class="fas fa-angle-down"></i></span><span
                                                            class="mdp-up-icon">{% render 'mdp-weare-icon' with '008' %}</span></label>
                                                <div class="mdp-sub-menu">
                                                    {% for childlink in link.links %}
                                                        {% assign childlink_classes = '' %}
                                                        {% if childlink.active %}
                                                            {% assign childlink_classes = childlink_classes | append: ' mdp-active' %}
                                                        {% endif %}
                                                        {% if childlink.child_active %}
                                                            {% assign childlink_classes = childlink_classes | append: ' mdp-active-ancestor' %}
                                                        {% endif %}
                                                        {% if childlink.current %}
                                                            {% assign childlink_classes = childlink_classes | append: ' mdp-current' %}
                                                        {% endif %}
                                                        {% if childlink.child_current %}
                                                            {% assign childlink_classes = childlink_classes | append: ' mdp-current-ancestor' %}
                                                        {% endif %}
                                                        {% if childlink.links != blank %}
                                                            <div class="mdp-menu-item mdp-has-children{{ childlink_classes }}">
                                                                <a href="{{ childlink.url }}" class="mdp-menu-link">
                                                                    {{ childlink.title | escape }}
                                                                    <span class="mdp-right-icon">{% render 'mdp-weare-icon' with '007' %}</span>
                                                                </a>
                                                                <input id="{{ childlink.url | md5 | slice: 0, 5 | prepend: 'id' }}"
                                                                       type="checkbox">
                                                                <label for="{{ childlink.url | md5 | slice: 0, 5 | prepend: 'id' }}"><span
                                                                            class="mdp-down-icon"><i
                                                                                class="fas fa-angle-down"></i></span><span
                                                                            class="mdp-up-icon">{% render 'mdp-weare-icon' with '008' %}</span></label>
                                                                <div class="mdp-sub-menu">
                                                                    {% for grandchildlink in childlink.links %}
                                                                        {% assign grandchildlink_classes = '' %}
                                                                        {% if grandchildlink.active %}
                                                                            {% assign grandchildlink_classes = grandchildlink_classes | append: ' mdp-active' %}
                                                                        {% endif %}
                                                                        {% if grandchildlink.child_active %}
                                                                            {% assign grandchildlink_classes = grandchildlink_classes | append: ' mdp-active-ancestor' %}
                                                                        {% endif %}
                                                                        {% if grandchildlink.current %}
                                                                            {% assign grandchildlink_classes = grandchildlink_classes | append: ' mdp-current' %}
                                                                        {% endif %}
                                                                        {% if grandchildlink.child_current %}
                                                                            {% assign grandchildlink_classes = grandchildlink_classes | append: ' mdp-current-ancestor' %}
                                                                        {% endif %}
                                                                        <div class="mdp-menu-item{{ grandchildlink_classes }}">
                                                                            <a href="{{ grandchildlink.url }}"
                                                                               class="mdp-menu-link">{{ grandchildlink.title | escape }}</a>
                                                                        </div>
                                                                    {% endfor %}
                                                                </div>
                                                            </div>
                                                        {% else %}
                                                            <div class="mdp-menu-item{{ childlink_classes }}">
                                                                <a href="{{ childlink.url }}"
                                                                   class="mdp-menu-link">{{ childlink.title | escape }}</a>
                                                            </div>
                                                        {% endif %}
                                                    {% endfor %}
                                                </div>
                                            </div>
                                        {% else %}
                                            <div class="mdp-menu-item{{ link_classes }}">
                                                <a href="{{ link.url }}"
                                                   class="mdp-menu-link">{{ link.title | escape }}</a>
                                            </div>
                                        {% endif %}
                                    {% endfor %}

                                    <div class="mdp-mobile-devices-footer">

                                        <div class="mdp-language-region">
                                            <h3>Language & Region:</h3>
                                            {% form 'localization' %}
                                                <select name="country_code">
                                                    {% for country in localization.available_countries %}
                                                        <option value="{{ country.iso_code }}" {% if country == localization.country %} selected="selected"{% endif %}>
                                                            {{ country.name }} ({{ country.iso_code }})
                                                            - {{ country.currency.symbol }}
                                                        </option>
                                                    {% endfor %}
                                                </select>
                                            {% endform %}

                                            {% form 'localization' %}
                                                <select name="language_code">
                                                    {% for language in localization.available_languages %}
                                                        <option value="{{ language.iso_code }}" {% if language == localization.language %} selected="selected"{% endif %}>
                                                            {{ language.endonym_name }}
                                                        </option>
                                                    {% endfor %}
                                                </select>
                                            {% endform %}
                                        </div>

                                        <div class="mdp-follow-us">
                                            <h3>Follow Us:</h3>
                                            <span class="mdp-info-list">
                                                {% for block in section.blocks %}
                                                    {% if block.type == "mobile_icons" %}
                                                        <span class="mdp-info">
                                                        <a href="{{ block.settings.social_link }}"
                                                          class="mdp-social-link"
                                                        >
                                                          <i class="{{ block.settings.icon_class }}"></i>
                                                        </a>
                                                        </span>
                                                    {% endif %}
                                                {% endfor %}
                                            </span>
                                        </div>

                                        <div class="mdp-my-account">
                                            <h3>My Account:</h3>
                                            <a href="/account/register" class="btn primary">Sign Up</a>
                                            <a href="/account" class="btn bordered-black">Login</a>
                                        </div>

                                        <div class="mdp-work-time-box">
                                            {% for block in section.blocks %}
                                                {% if block.type == "work_time" %}
                                                    <span class="mdp-info-list">
                                                        <span class="mdp-info mdp-work-time">
                                                            <span><i class="fas fa-clock"></i> Opening time:&nbsp;</span>
                                                            <span>{{ block.settings.work_time_text }}</span>
                                                        </span>
                                                    </span>
                                                {% endif %}
                                            {% endfor %}
                                        </div>

                                    </div>

                                </div>
                            </div>
                        </div>
                    {% endif %}


                   

                </div>
            </div>
           </div>
          
        </div>

        <div class="bottom-header">
