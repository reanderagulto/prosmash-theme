                        {% if menu and menu.links.size > 0 %}
                            <ul class="toggle-menu">
                            {% for link in menu.links %}
                                {% assign obj = link.object %}
                                {% assign img_url = '' %}

                                {% if link.type == 'collection_link' and obj %}
                                {% if obj.image %}
                                    {% assign img_url = obj.image | image_url: width: 800 %}
                                {% elsif obj.featured_image %}
                                    {% assign img_url = obj.featured_image | image_url: width: 800 %}
                                {% endif %}
                                {% endif %}

                                <li>
                                <a href="{{ link.url }}" class="toggle-link" data-image="{{ img_url }}">
                                    {{ link.title }}
                                </a>
                                </li>
                            {% endfor %}
                            </ul>

                            <div class="menu-drawer-img-container">
                                <canvas id="category-canvas"></canvas>
                            </div>
                        {% endif %}
