<section class="prosmash-collection-grid">
  <div class="mdp-container">
    <div class="filter-section">
      <div class="custom-container">
        <div class="col-left">
          <div class="collection-title">
            {{ collection.title }} ({{ collection.products_count }})
          </div>
        </div>
        <div class="col-right">
          <div class="filter-container">
            {% render 'faceted-filter' %}
          </div>
        </div>
      </div>
    </div>

    <div id="CollectionProductGrid">
      {% paginate collection.products by 12 %}
        <div class="collection-grid">
          {% for product in collection.products %}
            {% comment %} {% render 'prosmash-product-card', product: product %} {% endcomment %}
            {% render 'prosmash-product-card-v2', product: product %}
          {% endfor %}
        </div>

        {% if paginate.next %}
          <div class="load-more-wrapper">
            <button class="load-more" data-next-url="{{ paginate.next.url }}">Load More</button>
          </div>
        {% endif %}
      {% endpaginate %}
    </div>
  </div>
</section>


<style>
  .prosmash-collection-grid {
    padding: 0 64px 80px;
  }
  #CollectionProductGrid {
    max-width: 1342px;
    width: 100%;
    margin: 0 auto;
  }
  .filter-section {
    position: relative;
    z-index: 10;
  }
  .filter-section .custom-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 40px 0 52px;
  }
  .filter-section .custom-container .collection-title {
      color: var(--black);
      font-size: 24px;
      font-style: normal;
      font-weight: 600;
      line-height: 1.3;
  }

  .collection-grid {
    display: flex;
    flex-wrap: wrap;
    align-items: stretch;
    flex-wrap: wrap;
    width: 100%;
    gap: 24px;
  }

  .collection-grid .product-card-v2 {
    flex: 0 0 calc(calc(100% / 4) - 18px);
    width: calc(calc(100% / 4) - 24px);
    display: flex;
    flex-direction: column;
  }

  .collection-grid .product-card-v2 .btn {
    margin-top: auto;
  }

  button.load-more {
    border: 0px;
    color: var(--hover-grey);
    font-family: var(--font-body-family);
    border-bottom: 1px solid var(--hover-grey);
    background: unset;
    font-size: 16px;
    font-weight: 400;
    line-height: 1.5;
    padding: 0;
    margin: 0;
    cursor: pointer;
    transition: 0.3s;
  }
  button.load-more:hover {
      color: var(--black);
      border-color: var(--black);
  }
  .load-more-wrapper {
      margin: 56px 0 0px;
      text-align: center;;
  }
  @media (max-width: 991px) {

    .prosmash-collection-grid {
       padding-inline: 0;
    }
    .collection-grid .product-card-v2 {
        flex: 0 0 calc(calc(100% / 2) - 12px);
        width: calc(calc(100% / 2) - 24px);
    }
  }

  @media (max-width: 480px) {
    .collection-grid .product-card-v2 {
        flex: 0 0 100%;
        width: 100%;
    }
  }

</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const form = document.querySelector('#CollectionFiltersForm');
    const productGrid = document.querySelector('#CollectionProductGrid');

    if (!form || !productGrid) return;

    form.addEventListener('change', function (e) {
      e.preventDefault();

      const formData = new FormData(form);
      const searchParams = new URLSearchParams(formData).toString();

      fetch(`${window.location.pathname}?section_id=prosmash-collection-grid&${searchParams}`)
        .then(response => response.text())
        .then(responseText => {
          const parser = new DOMParser();
          const html = parser.parseFromString(responseText, 'text/html');
          const newGrid = html.querySelector('#CollectionProductGrid');
          if (newGrid) {
            productGrid.innerHTML = newGrid.innerHTML;
            window.history.replaceState({}, '', `${window.location.pathname}?${searchParams}`);
            bindLoadMore(); // re-bind load more after refresh
          }
        });
    });

    function bindLoadMore() {
      const loadMoreBtn = document.querySelector('.load-more');
      if (!loadMoreBtn) return;

      loadMoreBtn.addEventListener('click', function () {
        const nextUrl = loadMoreBtn.dataset.nextUrl;
        if (!nextUrl) return;

        loadMoreBtn.disabled = true;
        loadMoreBtn.innerText = 'Loading...';

        fetch(`${nextUrl}&section_id=prosmash-collection-grid`)
          .then(res => res.text())
          .then(html => {
            const parser = new DOMParser();
            const doc = parser.parseFromString(html, 'text/html');
            const newItems = doc.querySelectorAll('.collection-grid > *');
            const newButton = doc.querySelector('.load-more-wrapper');

            const grid = productGrid.querySelector('.collection-grid');
            newItems.forEach(item => grid.appendChild(item));

            loadMoreBtn.parentElement.remove();

            if (newButton) {
              productGrid.appendChild(newButton);
              bindLoadMore(); // rebind new button
            }
          });
      });
    }

    bindLoadMore(); // bind on initial load

    // Initialize wishlist functionality
    function getStorageKey() {
      const firstWishlistBtn = document.querySelector('.mdp-add-to-wishlist');
      const customerId = firstWishlistBtn ? firstWishlistBtn.dataset.customerId : null;
      return customerId ? `mdp-wishlist-customer-${customerId}` : 'mdp-wishlist-temp';
    }

    const storageKey = getStorageKey();
    const wishlist = JSON.parse(localStorage.getItem(storageKey) || '{}');
    document.querySelectorAll('.mdp-add-to-wishlist').forEach(btn => {
      const handle = btn.dataset.productHandle;
      if (handle in wishlist) {
        btn.classList.add('mdp-added');
      }
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        const productHandle = this.dataset.productHandle;
        if (!productHandle) return;

        const currentStorageKey = getStorageKey();
        const currentWishlist = JSON.parse(localStorage.getItem(currentStorageKey) || '{}');
        if (productHandle in currentWishlist) {
          delete currentWishlist[productHandle];
          this.classList.remove('mdp-added');
        } else {
          currentWishlist[productHandle] = 'added';
          this.classList.add('mdp-added');
          // Show popup
          const existingPopup = document.getElementById('wishlist-popup');
          if (existingPopup) existingPopup.remove();
          const popup = document.createElement('div');
          popup.id = 'wishlist-popup';
          popup.className = 'wishlist-popup';
          popup.textContent = 'Product added to wishlist!';
          document.body.appendChild(popup);
          popup.style.display = 'none';
          popup.style.position = 'fixed';
          popup.style.top = '20px';
          popup.style.right = '20px';
          popup.style.backgroundColor = '#4CAF50';
          popup.style.color = 'white';
          popup.style.padding = '16px';
          popup.style.borderRadius = '4px';
          popup.style.zIndex = '1000';
          popup.style.opacity = '0';
          popup.style.transition = 'opacity 0.3s';
          // Fade in
          setTimeout(() => {
            popup.style.display = 'block';
            setTimeout(() => {
              popup.style.opacity = '1';
            }, 10);
          }, 10);
          // Fade out
          setTimeout(() => {
            popup.style.opacity = '0';
            setTimeout(() => {
              popup.remove();
            }, 300);
          }, 2000);
        }
        localStorage.setItem(currentStorageKey, JSON.stringify(currentWishlist));
      });
    });
  });
</script>




