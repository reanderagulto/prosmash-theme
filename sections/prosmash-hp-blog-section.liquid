{{ "prosmash-global.css" | asset_url | stylesheet_tag }}

<section class="blogs">
  <div class="blogs-container">
    {% assign latest_posts = blogs.news.articles | slice: 0, 3 %}
    {% for article in latest_posts %}
      <div class="blog-item">
        <a href="{{ article.url }}">
          <div class="card-img" style="background-image: url({{ article.image | img_url: '3000x' }})"></div>
          <div class="card-content">
            <div class="date">{{ article.published_at | date: "%B %d, %Y" }}</div>
            <div class="title">{{ article.title }}</div>
          </div>
        </a>
      </div>
    {% endfor %}
  </div>
</section>



{% schema %}
{
  "name": "Prosmash HP Blog Section",
  "settings": [
   
  ],
  "presets": [{
    "name": "Prosmash HP Blog Section",
    "category": "Prosmash"
  }]
}
{% endschema %}